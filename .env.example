# ═══════════════════════════════════════════════════════════════
# CodeLab Monitoring Stack — Variables d'environnement
# IMPORTANT : Ne jamais committer ce fichier dans Git
# Copier .env.example en .env et remplir les valeurs
# ═══════════════════════════════════════════════════════════════

# Optionnel : préfixe volumes Docker (défaut = nom du dossier du projet, ex. codelab_monitoring)
# COMPOSE_PROJECT_NAME=monitoring

# ── Domaine ─────────────────────────────────────────────────────
GRAFANA_DOMAIN=monitoring.codelab.bj

# ── Grafana ──────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=ChangeMoi_MotDePasseForte_2024!

# ── Loki Auth (Basic Auth pour les agents Promtail distants) ────
# Générer avec : htpasswd -nb paygate motdepasse
LOKI_USERNAME_PAYGATE=paygate
LOKI_PASSWORD_PAYGATE=ChangeMoi_LokiPaygate_2024!

LOKI_USERNAME_PROJETB=projetb
LOKI_PASSWORD_PROJETB=ChangeMoi_LokiProjetB_2024!

LOKI_USERNAME_PROJETC=projetc
LOKI_PASSWORD_PROJETC=ChangeMoi_LokiProjetC_2024!

# ── SMTP (pour alertes Grafana + Alertmanager) ──────────────────
# Gmail : utiliser un « mot de passe d'application » si la 2FA est activée
SMTP_HOST=smtp.gmail.com:587
SMTP_USER=codelabmonitoring@gmail.com
SMTP_PASSWORD=ChangeMoi_SmtpPassword!
SMTP_FROM=codelabmonitoring@gmail.com

# ── Email destinataires (référence ; Alertmanager : voir configs/alertmanager.yml) ─
ALERT_EMAIL_PRIMARY=codelabbj@gmail.com
ALERT_EMAIL_SECONDARY=codelabbj@gmail.com

# ── Telegram (Alertmanager → service alertmanager_telegram) ─────
# Bot : @BotFather — démarrer une discussion avec ton bot (ou l’ajouter à un groupe)
TELEGRAM_BOT_TOKEN=remplacer_par_token_botfather
TELEGRAM_CHAT_ID=123456789

# ── Alertmanager SMTP ───────────────────────────────────────────
# Le mot de passe n'est pas dans configs/alertmanager.yml : après toute modif de
# SMTP_PASSWORD, lancer : bash scripts/sync-secrets-from-env.sh
# puis : docker compose restart alertmanager

# ── Portainer ───────────────────────────────────────────────────
# Le mot de passe est dans ./secrets/portainer_password.txt
# Format bcrypt — générer avec :
# docker run --rm httpd:2.4-alpine htpasswd -nbB admin "motdepasse" | cut -d":" -f2

# ── Prometheus Basic Auth (optionnel, pour sécuriser /metrics) ──
PROMETHEUS_USERNAME=prometheus
PROMETHEUS_PASSWORD=ChangeMoi_PrometheusPass_2024!
