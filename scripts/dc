#!/usr/bin/env bash
# Wrapper docker compose (chemins absolus + project-directory) — Snap-safe, comme dans manage.sh
# Exemples : bash scripts/dc ps   |   bash scripts/dc logs grafana   |   bash scripts/dc up -d
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"
exec docker compose -f "${ROOT}/docker-compose.yml" --project-directory "${ROOT}" "$@"
